{
  "name": "@planweave-ai/desktop",
  "version": "0.2.2",
  "description": "Desktop application for PlanWeave plan packages, task graphs, and agent workflows.",
  "license": "MIT",
  "author": "GaosCode <GaosCode@users.noreply.github.com>",
  "type": "module",
  "main": "./dist/main/main.js",
  "homepage": "https://github.com/GaosCode/PlanWeave#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GaosCode/PlanWeave.git",
    "directory": "packages/desktop"
  },
  "bugs": {
    "url": "https://github.com/GaosCode/PlanWeave/issues"
  },
  "keywords": [
    "planweave",
    "desktop",
    "ai-agents",
    "task-graph",
    "workflow"
  ],
  "scripts": {
    "build": "pnpm --filter @planweave-ai/runtime build && pnpm --filter @planweave-ai/mcp build && pnpm --filter @planweave-ai/server build && tsc -p tsconfig.json && tsc -p tsconfig.main.json --noEmit && node scripts/build-electron.mjs && vite build",
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "dist:all": "pnpm build && electron-builder --mac dmg zip --linux AppImage deb tar.gz --win nsis zip --publish never",
    "dist:linux": "pnpm build && electron-builder --linux AppImage deb tar.gz --publish never",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip --publish never",
    "dist:win": "pnpm build && electron-builder --win nsis zip --publish never",
    "pack:all": "pnpm build && electron-builder --mac --linux --win --dir --publish never",
    "pack:linux": "pnpm build && electron-builder --linux --dir --publish never",
    "pack:mac": "pnpm build && electron-builder --mac --dir --publish never",
    "pack:win": "pnpm build && electron-builder --win --dir --publish never",
    "release:all": "node -e \"console.error('Desktop releases must use the manual GitHub Actions Desktop Release workflow. Use dist:* for local build-only artifacts.'); process.exit(1)\"",
    "release:linux": "node -e \"console.error('Desktop releases must use the manual GitHub Actions Desktop Release workflow. Use dist:* for local build-only artifacts.'); process.exit(1)\"",
    "release:mac": "node -e \"console.error('Desktop releases must use the manual GitHub Actions Desktop Release workflow. Use dist:* for local build-only artifacts.'); process.exit(1)\"",
    "release:win": "node -e \"console.error('Desktop releases must use the manual GitHub Actions Desktop Release workflow. Use dist:* for local build-only artifacts.'); process.exit(1)\"",
    "start": "electron dist/main/main.js",
    "smoke": "tsx scripts/electron-smoke.ts",
    "smoke:packaged:mac": "PLANWEAVE_DESKTOP_SMOKE_PACKAGED=1 tsx scripts/electron-smoke.ts",
    "verify:packaged:mac": "pnpm pack:mac && node scripts/verify-packaged-app.mjs",
    "verify:release-assets": "node scripts/verify-release-assets.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@planweave-ai/mcp": "workspace:*",
    "@planweave-ai/runtime": "workspace:*",
    "@planweave-ai/server": "workspace:*",
    "@xyflow/react": "^12.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-liquid-glass": "^1.1.1",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "lucide-react": "^0.554.0",
    "ms": "^2.1.3",
    "node-gyp-build": "^4.8.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0"
  },
  "build": {
    "appId": "dev.planweave.desktop",
    "productName": "PlanWeave",
    "executableName": "PlanWeave",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/electron-liquid-glass/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null,
      "x64ArchFiles": "**/node_modules/electron-liquid-glass/prebuilds/darwin-*/**/*.node",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "Development",
      "icon": "build/icon.png",
      "maintainer": "GaosCode <GaosCode@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "GaosCode",
        "repo": "PlanWeave",
        "releaseType": "release"
      }
    ],
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  }
}
