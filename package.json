{
  "name": "planweave",
  "version": "0.1.4",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "check:dom-boundaries": "node scripts/check-renderer-dom-boundaries.mjs",
    "check:versions": "node scripts/sync-version-metadata.mjs --check",
    "desktop:build": "pnpm --dir packages/desktop build",
    "desktop:dist:all": "pnpm --dir packages/desktop dist:all",
    "desktop:dist:linux": "pnpm --dir packages/desktop dist:linux",
    "desktop:dist:mac": "pnpm --dir packages/desktop dist:mac",
    "desktop:dist:win": "pnpm --dir packages/desktop dist:win",
    "desktop:pack:all": "pnpm --dir packages/desktop pack:all",
    "desktop:pack:linux": "pnpm --dir packages/desktop pack:linux",
    "desktop:pack:mac": "pnpm --dir packages/desktop pack:mac",
    "desktop:pack:win": "pnpm --dir packages/desktop pack:win",
    "desktop:release:all": "pnpm --dir packages/desktop release:all",
    "desktop:release:linux": "pnpm --dir packages/desktop release:linux",
    "desktop:release:mac": "pnpm --dir packages/desktop release:mac",
    "desktop:release:win": "pnpm --dir packages/desktop release:win",
    "desktop:verify:packaged:mac": "pnpm --dir packages/desktop verify:packaged:mac",
    "pack:npm": "pnpm -r --filter @planweave-ai/runtime --filter @planweave-ai/cli pack",
    "planweave": "pnpm --filter @planweave-ai/cli planweave",
    "publish:npm": "pnpm -r --filter @planweave-ai/runtime --filter @planweave-ai/cli publish --access public",
    "sync:versions": "node scripts/sync-version-metadata.mjs",
    "test": "pnpm check:versions && pnpm check:dom-boundaries && vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
