{
  "name": "planweave",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "check:dom-boundaries": "node scripts/check-renderer-dom-boundaries.mjs",
    "pack:npm": "pnpm -r --filter @planweave/runtime --filter @planweave/cli pack",
    "publish:npm": "pnpm -r --filter @planweave/runtime --filter @planweave/cli publish --access public",
    "test": "pnpm check:dom-boundaries && vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
